{
  "name": "@juanhernandez-rlw/design-system",
  "version": "0.1.0",
  "description": "Mini design system — Button, Input, Card. Built to be consumed across projects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.1.0",
    "typescript": "^5.9.0"
  },
  "license": "MIT",
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui"
  ]
}
